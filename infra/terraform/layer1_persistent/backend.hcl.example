# Copy to backend.hcl and fill in, then: terraform init -backend-config=backend.hcl
# The state bucket must exist first (create it once, out-of-band). S3 native
# locking (use_lockfile) needs no DynamoDB table.
bucket = "CHANGE_ME-terraform-state"
key    = "aether/layer1_persistent/terraform.tfstate"
region = "ap-southeast-1"
