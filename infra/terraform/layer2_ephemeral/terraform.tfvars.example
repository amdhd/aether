# Copy to terraform.tfvars and adjust. layer1_state_bucket is required so this
# stack can read layer1's outputs (ECR repo, secret ARN, CloudFront domain).

layer1_state_bucket = "CHANGE_ME-terraform-state"
image_tag           = "latest"

# Cost/scale knobs (defaults are the cheap single-AZ demo). Flip one boolean for
# the full production-grade shape (Multi-AZ RDS + autoscaling + Redis):
high_availability = false

# db_instance_class = "db.t4g.small"
# ecs_task_cpu      = 512
# ecs_task_memory   = 1024
# api_desired_count = 1

# alert_email = "you@example.com"   # CloudWatch alarm notifications

# Custom domain → HTTPS on the API (recommended). Requires a Route53 hosted zone
# you own. Leave both empty for an HTTP-only demo (frontend-over-HTTPS won't be
# able to call it, so a domain is needed for a working end-to-end demo).
# api_domain_name  = "api.example.com"
# hosted_zone_name = "example.com"
