# --- App ---
# Set to "production" in deployed environments. This enables strict startup
# checks (e.g. SECRET_KEY/ENCRYPTION_KEY must not be left at their defaults).
ENVIRONMENT=development

# --- Database ---
POSTGRES_USER=aether
POSTGRES_PASSWORD=aether
POSTGRES_DB=aether
# Used by Alembic / app when running outside docker compose
DATABASE_URL=postgresql+asyncpg://aether:aether@localhost:5432/aether

# --- Auth / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Refresh-token cookie ---
# The refresh token is delivered as an HttpOnly cookie. For local dev the
# defaults below are fine. In production, if the frontend and API are on
# different domains (e.g. Vercel + Render), set:
#   REFRESH_COOKIE_SECURE=true and REFRESH_COOKIE_SAMESITE=none
# or, better, host the API on a subdomain of the frontend and set
# REFRESH_COOKIE_DOMAIN=.yourdomain.com with SAMESITE=lax.
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=

# --- Encryption (Fernet key for OAuth tokens at rest) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-with-fernet

# --- CORS ---
# Comma-separate to allow multiple origins, e.g. http://localhost:5173,http://127.0.0.1:5173
FRONTEND_ORIGIN=http://localhost:5173

# --- Proxy ---
# Set to true when deployed behind a reverse proxy you control (Render, Vercel,
# nginx) so per-IP auth rate limiting reads the real client IP from
# X-Forwarded-For. Leave false in local dev; enabling it lets clients spoof
# their IP if no trusted proxy actually sets the header.
TRUST_PROXY_HEADERS=false

# --- Tracing (OpenTelemetry) ---
# Optional. When true, the app auto-instruments FastAPI + SQLAlchemy + HTTPX.
# Spans print to stdout unless OTEL_EXPORTER_OTLP_ENDPOINT is set (in the AWS
# stack that's the ADOT sidecar → X-Ray, wired automatically when enable_tracing).
# TRACING_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Rate limiting (shared store) ---
# Optional. When set, rate limits are enforced globally in Redis (required once
# more than one API instance runs); unset = in-memory per-instance. Use rediss://
# for TLS. In the HA AWS stack this is wired to ElastiCache automatically.
# REDIS_URL=redis://localhost:6379

# --- LLM (DeepSeek) ---
# https://platform.deepseek.com
DEEPSEEK_API_KEY=

# --- Tools ---
# https://tavily.com (free tier)
TAVILY_API_KEY=
# Weather forecasts use the Malaysia data.gov.my API (no key required):
# https://developer.data.gov.my/realtime-api/weather

# --- Embeddings (semantic note search / RAG) ---
# https://platform.openai.com - used to embed notes for semantic search.
# Optional: if left blank, note search falls back to a keyword scan.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# Relevance floor (cosine distance, 0..2) for semantic note search. Matches
# beyond this are dropped as irrelevant. Lower = stricter.
NOTE_SEARCH_MAX_DISTANCE=0.6

# --- Google Calendar OAuth ---
# https://console.cloud.google.com - enable Calendar API, configure OAuth consent screen,
# create a Web application OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback

# --- Frontend ---
VITE_API_URL=http://localhost:8000
